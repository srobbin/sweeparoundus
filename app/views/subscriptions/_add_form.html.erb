<%= form_with url: create_subscription_path, method: :post, data: { controller: "search", action: "search#submit" } do |f| %>
  <%= f.hidden_field :t, value: token %>
  <label for="address" class="block font-medium sr-only">Search for a Chicago address</label>
  <div class="flex rounded-md shadow-sm">
    <div class="flex items-stretch flex-grow">
      <gmp-place-autocomplete
        name="address"
        id="address"
        class="search-autocomplete search-autocomplete--rounded-l"
        placeholder="e.g. 3324 North California Ave, Chicago, IL"
        included-primary-types="street_address"
        included-region-codes="us"
        data-search-target="address"
        data-action="gmp-select->search#placeChanged"
      ></gmp-place-autocomplete>
      <input type="hidden" name="lat" data-search-target="lat" />
      <input type="hidden" name="lng" data-search-target="lng" />
    </div>
    <button type="submit"
            data-search-target="submit"
            class="-ml-px relative inline-flex items-center justify-center w-20 px-4 py-2 border border-transparent font-medium rounded-r-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-1 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed"
            disabled>
      <%= icon "circle-notch", class: "hidden animate-spin h-5 w-5 text-white", data: { search_target: "spinner" }, aria: { hidden: true } %>
      <span data-search-target="label">Add</span>
    </button>
  </div>
<% end %>
