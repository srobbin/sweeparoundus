<%
  has_address = alert.street_address.present?
  is_pending = !alert.confirmed?
  status_id = "#{dom_id(alert)}-status"
  toggle_id = "#{dom_id(alert)}-permit-notifications"
  display_address = has_address ? alert.street_address : "(no specific address)"
  remove_label = "Remove subscription for #{display_address}"
  remove_confirm = has_address ? "Stop receiving sweeping alerts for #{alert.street_address}?" : "Stop receiving sweeping alerts for this area?"
  card_class = is_pending ? "subscription-card subscription-card--pending" : "subscription-card"
%>
<div id="<%= dom_id(alert) %>" class="<%= card_class %> px-3 sm:px-4 py-3">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
    <div class="flex-1 min-w-0">
      <div class="font-medium text-gray-900 <%= 'italic text-gray-500' unless has_address %>">
        <%= display_address %>
      </div>

      <div class="text-sm text-gray-700 mt-0.5">
        <% if alert.area %>
          <% if has_address %>
            <% next_sweep_text = alert.area.decorate.next_sweep %>
            <span>
              <span class="text-gray-500">Next sweep:</span>
              <span class="font-medium"><%= next_sweep_text %></span>
            </span>
            <span class="text-gray-300 mx-1.5" aria-hidden="true">·</span>
            <span class="text-xs text-gray-500"><%= alert.area.name %></span>
          <% else %>
            <span class="text-xs text-gray-500"><%= alert.area.name %></span>
          <% end %>
        <% else %>
          <span class="text-red-600 text-sm">Area no longer available</span>
        <% end %>
      </div>

      <% if has_address %>
        <%= form_with url: update_subscription_path(alert, t: token), method: :patch, class: "mt-1.5", data: { controller: "auto-submit" } do |f| %>
          <label for="<%= toggle_id %>" class="inline-flex items-center cursor-pointer text-xs text-gray-600 select-none">
            <span class="relative inline-block w-9 h-5 flex-shrink-0">
              <%= f.check_box :permit_notifications,
                    { id: toggle_id,
                      checked: alert.permit_notifications?,
                      class: "peer sr-only",
                      role: "switch",
                      aria: { label: "Temporary No Parking alerts for #{alert.street_address}" },
                      data: { action: "change->auto-submit#submit" } },
                    "1", "0" %>
              <span class="absolute inset-0 bg-gray-300 rounded-full transition-colors peer-checked:bg-blue-600 peer-focus-visible:ring-2 peer-focus-visible:ring-blue-500 peer-focus-visible:ring-offset-2" aria-hidden="true"></span>
              <span class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow transition-transform peer-checked:translate-x-4" aria-hidden="true"></span>
            </span>
            <span class="ml-2">Temporary &ldquo;No Parking&rdquo; alerts</span>
          </label>
        <% end %>
      <% else %>
        <p class="mt-1.5 text-xs text-gray-500">
          Add a street address to enable temporary &ldquo;No Parking&rdquo; alerts.
        </p>
      <% end %>
    </div>

    <div class="flex w-full items-center justify-between gap-2 sm:w-auto sm:flex-none sm:justify-end sm:gap-3">
      <div class="flex items-center gap-2">
        <% if alert.confirmed? %>
          <span id="<%= status_id %>"
                role="status"
                aria-label="Subscription active"
                class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-800">
            <%= icon "check-circle", variant: "fill", class: "h-3 w-3", aria: { hidden: true } %>
            Active
          </span>
        <% else %>
          <span id="<%= status_id %>"
                role="status"
                aria-label="Subscription pending confirmation"
                class="inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-800">
            Pending
          </span>
          <%= button_to confirm_subscription_path(alert, t: token),
                method: :patch,
                class: "inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-blue-500 shadow-sm",
                aria: { describedby: status_id } do %>
            Confirm
          <% end %>
        <% end %>
      </div>

      <%= button_to destroy_subscription_path(alert, t: token),
            method: :delete,
            class: "inline-flex items-center justify-center w-8 h-8 rounded-md text-gray-400 hover:text-red-700 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-red-500",
            aria: { label: remove_label },
            title: "Remove",
            data: { turbo_confirm: remove_confirm } do %>
        <%= icon "trash", class: "h-4 w-4", aria: { hidden: true } %>
      <% end %>
    </div>
  </div>
</div>
