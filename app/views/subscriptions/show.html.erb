<%= content_for :page_title, "Manage Subscriptions" %>

<div class="flex-1">
  <header class="bg-gray-100">
    <div class="flex items-center max-w-6xl mx-auto py-2 px-4">
      <div class="flex-1">
        <%= link_to image_tag("logo.png", class: "w-96", alt: "#{ENV["SITE_NAME"]} logo"), root_path %>
      </div>
    </div>
  </header>

  <main>
    <div class="max-w-3xl mx-auto px-4 py-8">
      <h1 class="text-2xl font-bold mb-1">Your subscriptions</h1>
      <p class="text-sm text-gray-500 mb-6">
        Signed in as <span class="text-gray-700"><%= @email %></span>.
        <%= link_to "Not you?", subscriptions_path, class: "underline hover:text-gray-700" %>
      </p>

      <div id="manage-flash">
        <%= render "shared/flash" %>
      </div>

      <section class="mb-10">
        <%= render "subscriptions",
              pending: @pending_alerts,
              active: @active_alerts,
              total_count: @alerts.size,
              token: @token %>
      </section>

      <section>
        <h2 class="text-xl font-bold mb-1">Add a subscription</h2>
        <p class="text-sm text-gray-600 mb-4">Search for a Chicago street address to subscribe to sweeping alerts.</p>

        <div id="add-subscription-flash"></div>
        <%= render "add_form", token: @token %>
      </section>
    </div>
  </main>
</div>
