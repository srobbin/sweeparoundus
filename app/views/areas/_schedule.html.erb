<% past_sweep_class = "px-4 py-3 whitespace-nowrap text-sm text-gray-300" %>
<% upcoming_sweep_class = "px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900" %>
<h2 class="mt-8 mb-2 text-xl font-bold">Sweep Schedule</h2>
<div class="border border-gray-200 rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <tbody class="divide-y divide-gray-100">
      <% @area.sweeps.each do |sweep| %>
        <% is_past = [sweep.date_1, sweep.date_2, sweep.date_3, sweep.date_4].all? { |date| date == "—" || Date.parse(date) < Date.today } %>
        <tr class="<%= cycle("bg-white", "bg-gray-50") %>">
          <td class="<%= is_past ? past_sweep_class : upcoming_sweep_class %>"><%= sweep.date_1 %></td>
          <td class="<%= is_past ? past_sweep_class : upcoming_sweep_class %>"><%= sweep.date_2 %></td>
          <td class="<%= is_past ? past_sweep_class : upcoming_sweep_class %>"><%= sweep.date_3 %></td>
          <td class="<%= is_past ? past_sweep_class : upcoming_sweep_class %>"><%= sweep.date_4 %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
