<div class="mt-8 border border-gray-200 bg-white rounded-lg p-5">
  <h2 class="flex items-center mb-2 text-lg font-semibold text-gray-900">
    <%= icon "checkerboard", class: "h-5 w-5 text-gray-400", aria: { hidden: true } %>
    <span class="ml-2">Adjacent Sweep Areas</span>
  </h2>
  <p class="text-sm text-gray-600 mb-4">Your address is near the edge of a sweep zone. Consider signing up for alerts in the adjacent sweep zone(s):</p>

  <div class="space-y-3">
    <% @neighbors.each do |neighbor| %>
      <div class="bg-white border border-gray-200 rounded-md p-4">
        <div class="flex items-center justify-between">
          <div>
            <%= link_to neighbor.area.name, area_path(neighbor.area, from_neighbor: 1), class: "text-blue-600 hover:text-blue-800 font-medium", target: "_blank", rel: "noopener noreferrer" %>
            <span class="text-xs text-gray-400 ml-1"><%= neighbor.area.shortcode %></span>
          </div>
          <span class="text-xs text-gray-500">&asymp; <%= neighbor.distance_feet %> ft <%= neighbor.direction %></span>
        </div>
        <% if neighbor.nearest_address.present? %>
          <p class="text-sm text-gray-500 italic mt-1">Near <%= neighbor.nearest_address %></p>
        <% end %>
        <p class="text-sm text-gray-700 mt-1">Next sweeps: <%= neighbor.area.next_sweep %></p>
      </div>
    <% end %>
  </div>
</div>
