<div class="space-y-4">
  <div class="border border-gray-200 rounded-lg p-5">
    <h2 class="flex items-center mb-3 text-lg font-semibold text-gray-900">
      <%= icon "envelope-simple", class: "h-5 w-5 text-gray-500", aria: { hidden: true } %>
      <span class="ml-2">Email Alerts</span>
    </h2>
    <p class="text-sm text-gray-600 mb-1">Get notified before sweeping day</p>
    <div id="subscribe">
      <%= render "alerts/form", area: @area %>
    </div>
  </div>

  <div class="border border-gray-200 rounded-lg p-5">
    <h2 class="flex items-center mb-3 text-lg font-semibold text-gray-900">
      <%= icon "calendar-blank", class: "h-5 w-5 text-gray-500", aria: { hidden: true } %>
      <span class="ml-2">Calendar Feed</span>
    </h2>
    <p class="text-sm text-gray-600 mb-3">Add sweep dates to iCal, Google Calendar, or Outlook</p>
    <%= link_to area_url(@area, format: :ics), class: "inline-flex items-center gap-1.5 px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-blue-500" do %>
    <%= icon "download-simple", class: "h-4 w-4", aria: { hidden: true } %>
    Download
    <% end %>
    <p class="text-xs text-gray-400 mt-3">May become outdated if the City updates its sweep schedule mid-season</p>
  </div>
</div>
