<% content_for :preheader do %>Confirm your subscription to street sweeping alerts for <%= @formatted_address_area %>.<% end %>

<p>Hello,</p>

<p>
  You are receiving this email because we have received a request to subscribe
  <strong><%= @email %></strong> to Chicago street sweeping alerts for <strong><%= @formatted_address_area %></strong>.
  Alerts will be sent out one day prior to a scheduled street sweeping.
</p>

<p>
  <%= link_to "Click here to confirm your subscription", @confirmation_url %>
</p>

<% if @static_map_url %>
  <p style="margin-bottom: 0;">
    <%= image_tag @static_map_url,
          alt: "Map showing the sweep area for #{@formatted_address_area}",
          width: AlertStaticMap::WIDTH,
          style: "max-width: 100%; height: auto; border: 1px solid #ccc; display: block;" %>
  </p>
  <p style="font-size: 12px; color: #555; margin-top: 0.25em;">
    The blue <strong>H</strong> marker is your address. The shaded area is the sweep zone.
  </p>
<% end %>

<%= render "shared/email_footer", disclaimer: true, coffee_link: false %>
