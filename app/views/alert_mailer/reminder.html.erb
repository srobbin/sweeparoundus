<% content_for :preheader do %>Heads up: street sweeping for <%= @street_address || @area.name %> begins tomorrow.<% end %>

<p>Hello,</p>

<% if @street_address %>
  <p>This is a reminder that street sweeping for <%= @street_address %> (<%= link_to @area.name, @area %>) will begin tomorrow.</p>
<% else %>
  <p>This is a reminder that street sweeping for <%= link_to @area.name, @area %> will begin tomorrow.</p>
<% end %>

<ul>
  <% @dates.each do |date| %>
    <li><%= date %></li>
  <% end %>
</ul>

<% if @static_map_url %>
  <p style="margin-bottom: 0;">
    <%= image_tag @static_map_url,
          alt: "Map showing the sweep area for #{@street_address || @area.name}",
          width: AlertStaticMap::WIDTH,
          style: "max-width: 100%; height: auto; border: 1px solid #ccc; display: block;" %>
  </p>
  <p style="font-size: 12px; color: #555; margin-top: 0.25em;">
    The blue <strong>H</strong> marker is your address. The shaded area is your sweep zone.
  </p>
<% end %>

<%= render "shared/email_footer", disclaimer: true, manage_url: @manage_url, unsubscribe_url: @unsubscribe_url %>
