<%# See _email_footer.html.erb for the full local-arg contract. The text
    version mirrors the HTML one but renders links inline in the
    "label (URL)" / "label: URL" forms that read cleanly as plain text
    (rather than as <a href> tags, which is how `link_to` would render
    in this format). %>
<% signoff      = local_assigns.fetch(:signoff, "Cheers,") %>
<% disclaimer   = local_assigns.fetch(:disclaimer, false) %>
<% manage_url   = local_assigns[:manage_url] %>
<% unsubscribe_url = local_assigns[:unsubscribe_url] %>
<% coffee_link  = local_assigns.fetch(:coffee_link, true) %>

<%= signoff %>
<%= ENV["SITE_NAME"] %> (<%= ENV["SITE_URL"] %>)
<% if disclaimer %>

<%= ApplicationMailer::DISCLAIMER %>
<% end %>
<% if manage_url %>

Manage subscriptions: <%= manage_url %>
<% end %>
<% if unsubscribe_url %>
Unsubscribe: <%= unsubscribe_url %>
<% end %>
<% if coffee_link && ENV["COFFEE_LINK_URL"].present? %>

☕ Enjoying this free service? Buy us a coffee: <%= ENV["COFFEE_LINK_URL"] %>
<% end %>
