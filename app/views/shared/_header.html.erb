<header class="bg-gray-100" data-controller="mobile-search">
  <div class="flex items-center max-w-6xl mx-auto py-2 px-4">
    <div class="flex-1">
      <%= link_to image_tag("logo.png", class: "w-96", alt: "#{ENV["SITE_NAME"]} logo"), root_path %>
    </div>
    <button type="button"
            class="lg:hidden p-2 text-gray-500 hover:text-gray-700"
            data-action="mobile-search#toggle"
            data-mobile-search-target="button"
            aria-label="Search"
            aria-controls="mobile-search-panel"
            aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
    </button>
    <div class="hidden lg:block">
      <%= render "search/form", variant: :secondary %>
    </div>
  </div>
  <div id="mobile-search-panel" class="hidden px-4 pb-3 lg:hidden" data-mobile-search-target="panel">
    <%= render "search/form", variant: :secondary %>
  </div>
</header>
