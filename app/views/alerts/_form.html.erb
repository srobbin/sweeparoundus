<%= form_with url: area_alerts_path(@area) do |f| %>
  <%= f.label :email, class: "sr-only" %>
  <% if @viewing_adjacent_area %>
    <%= hidden_field_tag :from_neighbor, 1 %>
    <div class="mt-4 flex gap-2 items-start bg-amber-50 border border-amber-200 rounded-md px-3 py-2">
      <%= icon "info", class: "h-5 w-5 text-amber-500 shrink-0", aria: { hidden: true } %>
      <p class="text-xs text-gray-500 leading-relaxed">
        Because sweep areas change annually, your subscription to notifications for this adjacent area will be deleted prior to the <%= (Date.current.year + 1).to_s %> sweep season.
      </p>
    </div>
  <% end %>
  <% if !@alert || !@alert.persisted? %>
    <div class="mt-4 flex flex-col">
      <% if @searched_address.present? %>
        <div class="flex gap-2 items-center">
          <%= f.check_box :is_save_street_address, checked: session[:is_save_street_address_checked], class: "h-4 w-4 rounded border-gray-400 text-blue-500 focus:ring-blue-500" %>
          <%= f.label :is_save_street_address, "Save my street address so I won't need to re-subscribe next year", class: "text-xs text-gray-500" %>
        </div>
      <% end %>
      <div class="flex mt-3">
        <div class="relative flex items-stretch flex-grow focus-within:z-10">
          <%= f.text_field :email, class: "focus:ring-blue-500 focus:border-blue-500 block w-full rounded-none rounded-l-md border-gray-300", placeholder: "you@example.com" %>
        </div>
        <button class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-transparent font-medium rounded-r-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-1 focus:ring-blue-500">
          Subscribe
        </button>
      </div>
    </div>
  <% end %>
<% end %>
