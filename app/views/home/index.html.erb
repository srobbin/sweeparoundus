<div class="flex-1 w-full flex items-center justify-center min-h-[80vh]">
  <div class="max-w-2xl mx-auto p-8 text-center">
    <%= image_tag "logo.png", class: "inline-block max-w-[280px] sm:max-w-md", alt: "#{ENV["SITE_NAME"]} logo" %>
    <div class="mt-5 mb-8">
      <%= render "shared/flash" %>
      <%= render "search/form" %>
    </div>
    <div class="grid grid-cols-3 gap-4 text-xs text-gray-500 max-w-sm mx-auto">
      <div class="flex flex-col items-center gap-1">
        <%= icon "magnifying-glass", class: "h-6 w-6", aria: { hidden: true } %>
        <span>Search address</span>
      </div>
      <div class="flex flex-col items-center gap-1">
        <%= icon "calendar-check", class: "h-6 w-6", aria: { hidden: true } %>
        <span>Get schedule</span>
      </div>
      <div class="flex flex-col items-center gap-1">
        <%= icon "bell-ringing", class: "h-6 w-6", aria: { hidden: true } %>
        <span>Get alerts</span>
      </div>
    </div>
    <%= render "important_note" %>
  </div>
</div>
