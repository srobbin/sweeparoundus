<ul>
  <% if match.segment_label.present? %>
    <li>
      <strong>Where:</strong> <%= match.segment_label %><% if match.distance_feet %> (about <%= match.distance_feet %> ft from your address)<% end %>
    </li>
  <% elsif match.distance_feet %>
    <li><strong>Distance:</strong> about <%= match.distance_feet %> ft from your address</li>
  <% end %>

  <% if match.permit_dates %>
    <li><strong>When:</strong> <%= match.permit_dates %></li>
  <% end %>

  <% if match.work_type_description.present? %>
    <li><strong>Work type:</strong> <%= match.work_type_description %></li>
  <% end %>

  <% if match.application_description.present? %>
    <li><strong>Description:</strong> <%= match.application_description %></li>
  <% end %>
</ul>

<% if match.static_map_url %>
  <p style="margin-bottom: 0;">
    <%= image_tag match.static_map_url,
          alt: "Map showing the permit area near #{@street_address}",
          width: PermitStaticMap::WIDTH,
          style: "max-width: 100%; height: auto; border: 1px solid #ccc; display: block;" %>
  </p>
  <p style="font-size: 12px; color: #555; margin-top: 0.25em;">
    The blue <strong>H</strong> marker is your address. The red line connects the two ends (<strong>A</strong> and <strong>B</strong>) of the permit's posted area.
  </p>
<% end %>
